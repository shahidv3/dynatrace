{
  "dashboard": {
    "__inputs": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "description": "Grafana Cloud Prometheus datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "pluginName": "Prometheus"
      }
    ],
    "__requires": [
      {
        "type": "grafana",
        "id": "grafana",
        "name": "Grafana",
        "version": "10.0.0"
      },
      {
        "type": "panel",
        "id": "stat",
        "name": "Stat",
        "version": ""
      },
      {
        "type": "panel",
        "id": "table",
        "name": "Table",
        "version": ""
      },
      {
        "type": "panel",
        "id": "timeseries",
        "name": "Time series",
        "version": ""
      },
      {
        "type": "datasource",
        "id": "prometheus",
        "name": "Prometheus",
        "version": ""
      }
    ],
    "annotations": {
      "list": []
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 0,
    "links": [],
    "liveNow": false,
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Critical Alerts",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "count(ALERTS{alertstate=\"firing\", severity=\"critical\"})",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": [
              "lastNotNull"
            ],
            "fields": ""
          },
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto",
          "orientation": "auto",
          "textMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "red",
                  "value": 1
                }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "High / Warning Alerts",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 4,
          "y": 0
        },
        "targets": [
          {
            "expr": "count(ALERTS{alertstate=\"firing\", severity=~\"high|warning\"})",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": [
              "lastNotNull"
            ],
            "fields": ""
          },
          "colorMode": "value",
          "graphMode": "none"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "orange",
                  "value": 1
                }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Affected Workloads / Services",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 8,
          "y": 0
        },
        "targets": [
          {
            "expr": "count(count by (cluster, namespace, workload, service) (ALERTS{alertstate=\"firing\"}))",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": [
              "lastNotNull"
            ],
            "fields": ""
          },
          "colorMode": "value",
          "graphMode": "none"
        }
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Affected Hosts",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "count(count by (instance) (ALERTS{alertstate=\"firing\", instance!=\"\"}))",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": [
              "lastNotNull"
            ],
            "fields": ""
          },
          "colorMode": "value",
          "graphMode": "none"
        }
      },
      {
        "id": 5,
        "type": "stat",
        "title": "Kubernetes Alerts",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 16,
          "y": 0
        },
        "targets": [
          {
            "expr": "count(ALERTS{alertstate=\"firing\", domain=\"kubernetes\"})",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": [
              "lastNotNull"
            ],
            "fields": ""
          },
          "colorMode": "value",
          "graphMode": "none"
        }
      },
      {
        "id": 6,
        "type": "stat",
        "title": "Infra / DB / App / Cert Alerts",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 20,
          "y": 0
        },
        "targets": [
          {
            "expr": "count(ALERTS{alertstate=\"firing\", domain=~\"linux|windows|database|application|certificate\"})",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": [
              "lastNotNull"
            ],
            "fields": ""
          },
          "colorMode": "value",
          "graphMode": "none"
        }
      },
      {
        "id": 7,
        "type": "table",
        "title": "Active Issues Now",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 10,
          "w": 24,
          "x": 0,
          "y": 4
        },
        "targets": [
          {
            "expr": "max by (alertname, severity, domain, env, cluster, instance, namespace, workload, service, team, root_cause) (ALERTS{alertstate=\"firing\"})",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [
            {
              "desc": true,
              "displayName": "severity"
            }
          ]
        },
        "transformations": [
          {
            "id": "labelsToFields",
            "options": {
              "mode": "columns"
            }
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "Value": false
              },
              "indexByName": {
                "severity": 0,
                "alertname": 1,
                "domain": 2,
                "env": 3,
                "cluster": 4,
                "instance": 5,
                "namespace": 6,
                "workload": 7,
                "service": 8,
                "team": 9,
                "root_cause": 10,
                "Value": 11
              },
              "renameByName": {
                "alertname": "Alert",
                "domain": "Domain",
                "env": "Env",
                "cluster": "Cluster",
                "instance": "Host",
                "namespace": "Namespace",
                "workload": "Workload",
                "service": "Service",
                "team": "Team",
                "root_cause": "Root Cause",
                "severity": "Severity",
                "Value": "State"
              }
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "auto"
            }
          }
        }
      },
      {
        "id": 8,
        "type": "table",
        "title": "Kubernetes Workload Health",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 0,
          "y": 14
        },
        "targets": [
          {
            "expr": "sum by (cluster, namespace, deployment) (kube_deployment_status_replicas_available)",
            "format": "table",
            "instant": true,
            "refId": "A"
          },
          {
            "expr": "sum by (cluster, namespace, statefulset) (kube_statefulset_status_replicas_ready)",
            "format": "table",
            "instant": true,
            "refId": "B"
          },
          {
            "expr": "sum by (cluster, namespace, daemonset) (kube_daemonset_status_number_ready)",
            "format": "table",
            "instant": true,
            "refId": "C"
          },
          {
            "expr": "sum by (cluster, namespace, pod) (increase(kube_pod_container_status_restarts_total[15m]))",
            "format": "table",
            "instant": true,
            "refId": "D"
          }
        ],
        "options": {
          "showHeader": true
        }
      },
      {
        "id": 9,
        "type": "table",
        "title": "Linux / Windows Host Health",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 12,
          "y": 14
        },
        "targets": [
          {
            "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "format": "table",
            "instant": true,
            "refId": "A"
          },
          {
            "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
            "format": "table",
            "instant": true,
            "refId": "B"
          },
          {
            "expr": "100 * (1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"}))",
            "format": "table",
            "instant": true,
            "refId": "C"
          },
          {
            "expr": "100 - (avg by (instance) (rate(windows_cpu_time_total{mode=\"idle\"}[5m])) * 100)",
            "format": "table",
            "instant": true,
            "refId": "D"
          },
          {
            "expr": "100 * (1 - (windows_os_physical_memory_free_bytes / windows_cs_physical_memory_bytes))",
            "format": "table",
            "instant": true,
            "refId": "E"
          }
        ],
        "options": {
          "showHeader": true
        }
      },
      {
        "id": 10,
        "type": "table",
        "title": "Database Health",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 23
        },
        "targets": [
          {
            "expr": "max by (instance) (mysql_up)",
            "format": "table",
            "instant": true,
            "refId": "A"
          },
          {
            "expr": "100 * (mysql_global_status_threads_connected / mysql_global_variables_max_connections)",
            "format": "table",
            "instant": true,
            "refId": "B"
          },
          {
            "expr": "rate(mysql_global_status_slow_queries[5m])",
            "format": "table",
            "instant": true,
            "refId": "C"
          },
          {
            "expr": "max by (instance) (pg_up)",
            "format": "table",
            "instant": true,
            "refId": "D"
          }
        ],
        "options": {
          "showHeader": true
        }
      },
      {
        "id": 11,
        "type": "table",
        "title": "Application Service Health",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 23
        },
        "targets": [
          {
            "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total[5m]))",
            "format": "table",
            "instant": true,
            "refId": "A"
          },
          {
            "expr": "100 * sum by (service_name) (rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[5m])) / sum by (service_name) (rate(traces_spanmetrics_calls_total[5m]))",
            "format": "table",
            "instant": true,
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.95, sum by (service_name, le) (rate(traces_spanmetrics_latency_bucket[5m])))",
            "format": "table",
            "instant": true,
            "refId": "C"
          }
        ],
        "options": {
          "showHeader": true
        }
      },
      {
        "id": 12,
        "type": "table",
        "title": "Certificate / Endpoint Health",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 23
        },
        "targets": [
          {
            "expr": "avg_over_time(probe_success[15m]) * 100",
            "format": "table",
            "instant": true,
            "refId": "A"
          },
          {
            "expr": "avg_over_time(probe_duration_seconds[15m])",
            "format": "table",
            "instant": true,
            "refId": "B"
          },
          {
            "expr": "probe_ssl_earliest_cert_expiry - time()",
            "format": "table",
            "instant": true,
            "refId": "C"
          }
        ],
        "options": {
          "showHeader": true
        }
      },
      {
        "id": 13,
        "type": "table",
        "title": "Noisy Alerts (Top 15 in 6h)",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 31
        },
        "targets": [
          {
            "expr": "topk(15, sum by (alertname, domain) (count_over_time(ALERTS{alertstate=\"firing\"}[6h])))",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "options": {
          "showHeader": true
        }
      },
      {
        "id": 14,
        "type": "table",
        "title": "Root Cause Distribution",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 31
        },
        "targets": [
          {
            "expr": "count by (root_cause) (ALERTS{alertstate=\"firing\", root_cause!=\"\"})",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "options": {
          "showHeader": true
        }
      }
    ],
    "refresh": "30s",
    "schemaVersion": 39,
    "style": "dark",
    "tags": [
      "command-center",
      "banking",
      "grafana-cloud",
      "triage"
    ],
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "label": "Datasource",
          "query": "prometheus",
          "current": {
            "selected": true,
            "text": "Prometheus",
            "value": "${DS_PROMETHEUS}"
          }
        },
        {
          "name": "cluster",
          "type": "query",
          "label": "Cluster",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "query": {
            "query": "label_values(kube_pod_info, cluster)",
            "refId": "StandardVariableQuery"
          },
          "refresh": 1,
          "multi": true,
          "includeAll": true
        },
        {
          "name": "namespace",
          "type": "query",
          "label": "Namespace",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "query": {
            "query": "label_values(kube_pod_info, namespace)",
            "refId": "StandardVariableQuery"
          },
          "refresh": 1,
          "multi": true,
          "includeAll": true
        },
        {
          "name": "severity",
          "type": "query",
          "label": "Severity",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "query": {
            "query": "label_values(ALERTS, severity)",
            "refId": "StandardVariableQuery"
          },
          "refresh": 1,
          "multi": true,
          "includeAll": true
        },
        {
          "name": "domain",
          "type": "query",
          "label": "Domain",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "query": {
            "query": "label_values(ALERTS, domain)",
            "refId": "StandardVariableQuery"
          },
          "refresh": 1,
          "multi": true,
          "includeAll": true
        }
      ]
    },
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {},
    "timezone": "",
    "title": "Command Center \u2013 Critical Banking Services Overview",
    "uid": "cmd-center-banking-overview",
    "version": 1,
    "weekStart": ""
  },
  "overwrite": false
}